# OpenRouter is the default. Free signup at https://openrouter.ai
# Free models used by default; no card required.
OPENROUTER_API_KEY=sk-or-v1-...

# Model used for the audit reasoning + native Arabic generation.
# Default is a free multimodal model that handles vision + JSON well.
AUDIT_MODEL=google/gemini-2.0-flash-exp:free

# Optional fallback if the primary model is rate-limited.
FALLBACK_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free

# Optional: route through OpenAI/Anthropic instead. If set, AUDIT_MODEL is
# interpreted in that provider's namespace. Leave blank to use OpenRouter.
PROVIDER=openrouter
